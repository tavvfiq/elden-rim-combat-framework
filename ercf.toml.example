# ERCF Configuration
#
# This file is a reference. At runtime ERCF will load:
# Data/SKSE/Plugins/<ERCF>/ercf.toml
#
# Any missing/invalid values fall back to the defaults below.

# Defense curve constant used by:
# PostDefense_T = ATK_T^2 / (ATK_T + k_defense * Defense_T)
k_defense = 1.0

# Resistance pacing constant used by:
# EffectivePayload = Payload / (1 + k_resist * ResValue_band)
k_resist = 1.0

# Layer-2 damage is clamped to avoid "100% immunity forever".
# DamageFloor_T = max(ATK_T * damage_floor_fraction, damage_floor_min)
damage_floor_fraction = 0.001
damage_floor_min = 0.0

# Status meter decay:
# - meter holds for status_decay_delay_seconds after last buildup
# - then decays by meter *= exp(-status_decay_rate * dt)
status_decay_delay_seconds = 0.75
status_decay_rate = 4.0

# Performance middle-ground:
# Cache per-actor summed resistance values (Immunity/Robustness) for this many seconds.
# This avoids scanning all ResBand active effects on every TESHitEvent.
status_resist_cache_ttl_seconds = 0.2

# Debugging (very spammy):
# When enabled, ERCF writes one ERCF.log line per non-blocked TESHitEvent.
debug_hit_log_enabled = false
# If enabled, only log every Nth hit (N >= 1).
debug_hit_log_every_n = 1

# When true (default), hit logs are written only if the actor currently selected
# in the Skyrim console matches the hit-event target actor.
debug_hit_log_require_console_target_match = true

# When true, emit logs even if the console-selected actor does not match.
# Helps diagnose why you see no hit logs.
debug_hit_log_log_selection_state = false

